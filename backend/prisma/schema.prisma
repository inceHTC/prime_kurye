generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// ENUM'LAR
// ================================
enum UserRole {
  INDIVIDUAL
  BUSINESS
  COURIER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PICKING_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
  FAILED
}

enum DeliveryType {
  EXPRESS
  SAME_DAY
  SCHEDULED
}

enum VehicleType {
  MOTORCYCLE
  CAR
  BICYCLE
}

enum EscrowStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ================================
// KULLANICI
// ================================
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String   @unique
  fullName      String
  password      String
  role          UserRole @default(BUSINESS)
  avatar        String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business?
  courier       Courier?
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  savedAddresses SavedAddress[]

  @@map("users")
}

// ================================
// İŞLETME
// ================================
model Business {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  taxNumber   String?
  address     String?
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@map("businesses")
}

// ================================
// KURYE
// ================================
model Courier {
  id                   String      @id @default(cuid())
  userId               String      @unique
  vehicle              VehicleType @default(MOTORCYCLE)
  plateNumber          String?
  isOnline             Boolean     @default(false)
  isApproved           Boolean     @default(false)
  currentLat           Float?
  currentLng           Float?
  locationUpdated      DateTime?
  rating               Float       @default(0)
  totalDeliveries      Int         @default(0)
  balance              Float       @default(0)
  weeklyEarnings       Float       @default(0)
  totalEarnings        Float       @default(0)
  pendingPayout        Float       @default(0)

  // Belgeler
  identityDoc          String?
  licenseDoc           String?
  vehicleDoc           String?
  criminalRecord       String?
  documentsSubmitted   Boolean     @default(false)
  documentsSubmittedAt DateTime?

  // Sözleşme
  contractSigned       Boolean     @default(false)
  contractSignedAt     DateTime?

  // IBAN bilgisi
  iban                 String?
  bankName             String?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders               Order[]
  payouts              Payout[]

  @@map("couriers")
}

// ================================
// SİPARİŞ
// ================================
model Order {
  id               String       @id @default(cuid())
  trackingCode     String       @unique
  status           OrderStatus  @default(PENDING)
  deliveryType     DeliveryType @default(EXPRESS)
  vehicle          VehicleType  @default(MOTORCYCLE)

  // Gönderici
  senderName       String
  senderPhone      String
  senderAddress    String
  senderLat        Float
  senderLng        Float
  senderNotes      String?

  // Alıcı
  recipientName    String
  recipientPhone   String
  recipientAddress String
  recipientLat     Float
  recipientLng     Float
  recipientNotes   String?

  // Paket
  packageDesc      String
  packageWeight    Float        @default(1)
  isFragile        Boolean      @default(false)
  packageValue     Float?

  // Fiyat
  price            Float
  insuranceValue   Float?
  isPaid           Boolean      @default(false)

  // Kurye eşleştirme
  assignedAt           DateTime?
  assignmentAttempts   Int       @default(0)
  pendingCourierIds    String[]
  rejectedCourierIds   String[]
  cancelReason         String?
  deliveryProofUrl     String?
  autoConfirmedAt      DateTime?

  // Escrow sistemi
  escrowAmount     Float?
  escrowStatus     EscrowStatus @default(PENDING)
  paidAt           DateTime?
  confirmedAt      DateTime?

  // Komisyon
  commissionRate   Float        @default(0.20)
  commissionAmount Float?
  courierAmount    Float?
  taxAmount        Float?

  // Zaman
  scheduledAt      DateTime?
  pickedUpAt       DateTime?
  deliveredAt      DateTime?
  estimatedAt      DateTime?

  // İlişkiler
  businessId       String
  courierId        String?
  business         Business     @relation(fields: [businessId], references: [id])
  courier          Courier?     @relation(fields: [courierId], references: [id])

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("orders")
}

// ================================
// HAFTALIK ÖDEME (KURYE)
// ================================
model Payout {
  id            String       @id @default(cuid())
  courierId     String
  amount        Float
  commission    Float
  tax           Float
  netAmount     Float
  status        PayoutStatus @default(PENDING)
  weekStart     DateTime
  weekEnd       DateTime
  paidAt        DateTime?
  bankName      String?
  iban          String?
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  courier       Courier      @relation(fields: [courierId], references: [id])

  @@map("payouts")
}

// ================================
// REFRESH TOKEN
// ================================
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ================================
// SİSTEM AYARLARI
// ================================
model SystemSettings {
  id                   String   @id @default(cuid())

  // Fiyatlandırma
  basePriceExpress     Float    @default(136.90)
  basePriceSameDay     Float    @default(94.90)
  basePriceScheduled   Float    @default(110.90)
  pricePerKmMoto       Float    @default(4.90)
  pricePerKmCar        Float    @default(7.90)
  pricePerKmBike       Float    @default(3.50)

  // Komisyon
  commissionRate       Float    @default(0.20)
  taxRate              Float    @default(0.18)
  courierPayRate       Float    @default(0.80)

  // Operasyon
  maxDeliveryRadius    Float    @default(15.0)
  pickupTimeoutMin     Int      @default(45)
  autoConfirmHours     Int      @default(24)
  minPayoutAmount      Float    @default(100.0)

  // Çalışma saatleri
  weekdayStart         String   @default("08:00")
  weekdayEnd           String   @default("22:00")
  weekendStart         String   @default("09:00")
  weekendEnd           String   @default("18:00")

  // Sigorta
  maxInsuranceAmount   Float    @default(30000.0)

  // Bildirim
  smsEnabled           Boolean  @default(false)
  emailEnabled         Boolean  @default(true)

  updatedAt            DateTime @updatedAt
  updatedBy            String?

  @@map("system_settings")
}


// ================================
// ADRES DEFTERİ
// ================================
model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String   // Ev, İş, Depo vb.
  address   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}